# =============================================================================
# Trosky — Environment Variables
# Copy this file to .env and fill in values before running the app.
# =============================================================================

# --- Database (required) ---
# PostgreSQL connection string. Docker default shown; replace with Neon/Supabase/etc. for hosted.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hotel_pricing

# --- Redis (optional) ---
# Required for scrape jobs, hotel refresh, and recommendation recompute.
# Without it, the app works but "Run scrape now" and "Refresh" return errors.
REDIS_URL=redis://localhost:6379

# --- Authentication (required in production) ---
# JWT signing secrets. MUST be long random strings in production.
# Generate with: openssl rand -hex 32
# WARNING: The app will crash on startup if these are missing in production.
JWT_SECRET=change-me-to-a-random-64-char-string-in-production-1234567890
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string-in-production-abc

# --- Scraping ---
# "mock" = deterministic fake prices (no Playwright needed, good for demos)
# "real" = Playwright-based OTA scraping (requires browser install)
SCRAPE_MODE=mock

# --- AI (optional) ---
# Set one or both for AI-powered rate explanations in recommendations.
# Without these, recommendations still work (deterministic engine) but won't have narrative text.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# --- Business rules ---
# Discount warning thresholds (percentages). Warnings appear in Day Detail modal
# and dashboard when ADR drops too far below BAR or discount share is too high.
DISCOUNT_ADR_THRESHOLD=12
DISCOUNT_SHARE_THRESHOLD=35

# --- UI (optional) ---
# Show demo login credentials on the login page. Only set to "true" for demos/staging.
# NEXT_PUBLIC_SHOW_DEMO_CREDENTIALS=true
